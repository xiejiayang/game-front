{
  "name": "dujiangyan-game",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test -c e2e/playwright.config.ts",
    "e2e:headed": "playwright test -c e2e/playwright.config.ts --headed",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "assets:cut-village": "node scripts/cut-village-paper.mjs",
    "assets:cut-walls": "node scripts/cut-paper.mjs --walls"
  },
  "dependencies": {
    "pixi.js": "^8.6.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.20.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
